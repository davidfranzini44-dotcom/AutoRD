# Copy to .env.local and fill in from your Supabase project settings
# (Project Settings → API). These are safe to expose in the browser.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Google Maps JavaScript API key for the /dealers map (billing-enabled Google
# Cloud project, Maps JavaScript API enabled). Restrict it to your domains.
# Leave blank to show the "add your key" fallback instead of the map.
VITE_GOOGLE_MAPS_API_KEY=
